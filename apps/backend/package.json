{
  "name": "@cityline/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name mobility-domain",
    "db:push": "prisma db push --skip-generate",
    "db:seed": "tsx prisma/seed.ts",
    "ingestion:enrich-paths": "tsx src/modules/ingestion/ingestion-cli.ts enrich-paths",
    "ingestion:normalize": "tsx src/modules/ingestion/ingestion-cli.ts normalize",
    "ingestion:import": "tsx src/modules/ingestion/ingestion-cli.ts import",
    "ingestion:reset-dev": "tsx src/modules/ingestion/ingestion-reset-dev.ts",
    "db:ensure:transport": "tsx src/modules/ingestion/ingestion-ensure-dev.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run db:push && npm run db:seed && vitest run"
  },
  "dependencies": {
    "@cityline/shared": "*",
    "@prisma/client": "^6.16.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.3",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.30.1",
    "prisma": "^6.16.2",
    "supertest": "^7.1.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.36.0",
    "vitest": "^3.2.4"
  }
}
